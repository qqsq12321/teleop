<mujoco model="inspire_hand_right">
  <compiler angle="radian" meshdir="./" autolimits="true"/>

  <option gravity="0 0 0"/>

  <default>
    <default class="inspire_hand">
      <joint damping="0.05"/>
      <position kp="3" dampratio="1"/>
      <geom density="800"/>

      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2" rgba="0.7 0.7 0.7 1"/>
      </default>
      <default class="collision">
        <geom group="3" type="box" mass="0" contype="0" conaffinity="0" rgba="0 0 0 0"/>
      </default>
    </default>
  </default>

  <visual>
    <global offwidth="1280" offheight="1280"/>
    <quality shadowsize="4096"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texrepeat="5 5" reflectance="0.2"/>
    <material name="hand_gray" rgba="0.65 0.65 0.65 1"/>
    <material name="hand_dark" rgba="0.3 0.3 0.3 1"/>

    <mesh name="right_base_link" file="meshes/mujoco_stl/right_base_link.stl"/>
    <mesh name="right_thumb_proximal_base" file="meshes/mujoco_stl/right_thumb_proximal_base.stl"/>
    <mesh name="right_thumb_proximal" file="meshes/mujoco_stl/right_thumb_proximal.stl"/>
    <mesh name="right_thumb_intermediate" file="meshes/mujoco_stl/right_thumb_intermediate.stl"/>
    <mesh name="right_thumb_distal" file="meshes/mujoco_stl/right_thumb_distal.stl"/>
    <mesh name="right_index_proximal" file="meshes/mujoco_stl/right_index_proximal.stl"/>
    <mesh name="right_index_intermediate" file="meshes/mujoco_stl/right_index_intermediate.stl"/>
    <mesh name="right_middle_intermediate" file="meshes/mujoco_stl/right_middle_intermediate.stl"/>
    <mesh name="right_pinky_intermediate" file="meshes/mujoco_stl/right_pinky_intermediate.stl"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <light pos="0.5 0.5 1" dir="-0.5 -0.5 -1"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Palm body with base_joint rotation (rpy="-1.57079 0 3.14159") -->
    <!-- Finger positions are in hand_base_link local frame (URDF original) -->
    <body name="palm" quat="0.000001 -0.000001 -0.707105 0.707109" childclass="inspire_hand">
      <geom type="mesh" mesh="right_base_link" class="visual" material="hand_gray"/>

      <!-- Thumb: xyz and rpy from URDF thumb_proximal_yaw_joint -->
      <body name="thumb_proximal_base" pos="-0.01696 -0.0691 -0.02045" quat="0.499998 0.500000 -0.500000 0.500002">
        <inertial pos="-0.0048064 0.0009382 -0.00757" quat="0.515015 0.680854 0.408023 0.323596" mass="0.0018869" diaginertia="8.66026e-08 6.8732e-08 4.94194e-08"/>
        <joint name="thumb_proximal_yaw_joint" axis="0 0 -1" range="0 1.308"/>
        <geom type="mesh" mesh="right_thumb_proximal_base" class="visual" material="hand_dark"/>
        <!-- thumb_proximal_pitch_joint rpy="1.5708 0 2.8587" -->
        <body name="thumb_proximal" pos="-0.0088099 0.010892 -0.00925" quat="0.099684 0.099685 0.700046 0.700044">
          <inertial pos="0.021932 0.012785 -0.0080386" quat="-0.254474 0.660716 0.251893 0.659733" mass="0.0066075" diaginertia="2.78601e-06 2.43933e-06 8.64566e-07"/>
          <joint name="thumb_proximal_pitch_joint" axis="0 0 1" range="0 0.6"/>
          <geom type="mesh" mesh="right_thumb_proximal" class="visual" material="hand_gray"/>
          <body name="thumb_intermediate" pos="0.04407 0.034553 -0.0008">
            <inertial pos="0.0095544 -0.0016282 -0.0071997" quat="0.636718 0.307389 -0.636802 0.307548" mass="0.0037847" diaginertia="4.6531e-07 4.48089e-07 2.45661e-07"/>
            <joint name="thumb_intermediate_joint" axis="0 0 1" range="0 0.8"/>
            <geom type="mesh" mesh="right_thumb_intermediate" class="visual" material="hand_gray"/>
            <body name="thumb_distal" pos="0.020248 0.010156 -0.0012">
              <inertial pos="0.0092888 0.0049529 -0.0060033" quat="-0.266294 0.655967 0.262806 0.655537" mass="0.0033441" diaginertia="2.0026e-07 1.95247e-07 8.1593e-08"/>
              <joint name="thumb_distal_joint" axis="0 0 1" range="0 0.4"/>
              <geom type="mesh" mesh="right_thumb_distal" class="visual" material="hand_gray"/>
            </body>
          </body>
        </body>
      </body>

      <!-- Index finger: xyz and rpy from URDF index_proximal_joint -->
      <body name="index_proximal" pos="0.00028533 -0.13653 -0.032268" quat="0.017445 -0.999848 0.000000 0.000000">
        <inertial pos="0.0012259 0.011942 -0.0060001" quat="0.50867 0.49121 -0.508643 0.491172" mass="0.0042403" diaginertia="6.9398e-07 6.62871e-07 2.10909e-07"/>
        <joint name="index_proximal_joint" axis="0 0 1" range="0 1.47"/>
        <geom type="mesh" mesh="right_index_proximal" class="visual" material="hand_gray"/>
        <body name="index_intermediate" pos="-0.0026138 0.032026 -0.001">
          <inertial pos="0.0019697 0.019589 -0.005" quat="0.466773 0.531152 -0.466773 0.531153" mass="0.0045683" diaginertia="7.8179e-07 7.72465e-07 8.47212e-08"/>
          <joint name="index_intermediate_joint" axis="0 0 1" range="-0.04545 1.56"/>
          <geom type="mesh" mesh="right_index_intermediate" class="visual" material="hand_gray"/>
        </body>
      </body>

      <!-- Middle finger -->
      <body name="middle_proximal" pos="0.00028533 -0.1371 -0.01295" quat="-0.000004 -1.000000 0.000000 0.000000">
        <inertial pos="0.001297 0.011934 -0.0060001" quat="0.510131 0.489693 -0.510105 0.489653" mass="0.0042403" diaginertia="6.9397e-07 6.62865e-07 2.10915e-07"/>
        <joint name="middle_proximal_joint" axis="0 0 1" range="0 1.47"/>
        <geom type="mesh" mesh="right_index_proximal" class="visual" material="hand_gray"/>
        <body name="middle_intermediate" pos="-0.0024229 0.032041 -0.001">
          <inertial pos="0.001921 0.020796 -0.005" quat="0.466148 0.531627 -0.466229 0.531705" mass="0.0050396" diaginertia="9.8384e-07 9.73279e-07 9.14014e-08"/>
          <joint name="middle_intermediate_joint" axis="0 0 1" range="-0.04545 1.56"/>
          <geom type="mesh" mesh="right_middle_intermediate" class="visual" material="hand_gray"/>
        </body>
      </body>

      <!-- Ring finger -->
      <body name="ring_proximal" pos="0.00028533 -0.13691 0.0062872" quat="0.026193 0.999657 0.000000 0.000000">
        <inertial pos="0.001297 0.011934 -0.0060002" quat="0.510129 0.489691 -0.510107 0.489654" mass="0.0042403" diaginertia="6.9397e-07 6.62865e-07 2.10915e-07"/>
        <joint name="ring_proximal_joint" axis="0 0 1" range="0 1.47"/>
        <geom type="mesh" mesh="right_index_proximal" class="visual" material="hand_gray"/>
        <body name="ring_intermediate" pos="-0.0024229 0.032041 -0.001">
          <inertial pos="0.0021753 0.019567 -0.005" quat="0.469554 0.528695 -0.469554 0.528695" mass="0.0045683" diaginertia="7.8177e-07 7.72448e-07 8.4722e-08"/>
          <joint name="ring_intermediate_joint" axis="0 0 1" range="-0.04545 1.56"/>
          <geom type="mesh" mesh="right_index_intermediate" class="visual" material="hand_gray"/>
        </body>
      </body>

      <!-- Pinky finger -->
      <body name="pinky_proximal" pos="0.00028533 -0.13571 0.025488" quat="0.052322 0.998630 0.000000 0.000000">
        <inertial pos="0.001297 0.011934 -0.0060001" quat="0.51013 0.489693 -0.510106 0.489653" mass="0.0042403" diaginertia="6.9397e-07 6.62865e-07 2.10915e-07"/>
        <joint name="pinky_proximal_joint" axis="0 0 1" range="0 1.47"/>
        <geom type="mesh" mesh="right_index_proximal" class="visual" material="hand_gray"/>
        <body name="pinky_intermediate" pos="-0.0024229 0.032041 -0.001">
          <inertial pos="0.0024748 0.016203 -0.0050031" quat="0.47398 0.528862 -0.469291 0.524799" mass="0.0035996" diaginertia="4.4867e-07 4.43723e-07 6.56538e-08"/>
          <joint name="pinky_intermediate_joint" axis="0 0 1" range="-0.04545 1.56"/>
          <geom type="mesh" mesh="right_pinky_intermediate" class="visual" material="hand_gray"/>
        </body>
      </body>
    </body>
  </worldbody>

  <contact>
    <exclude body1="palm" body2="thumb_proximal_base"/>
    <exclude body1="palm" body2="index_proximal"/>
    <exclude body1="palm" body2="middle_proximal"/>
    <exclude body1="palm" body2="ring_proximal"/>
    <exclude body1="palm" body2="pinky_proximal"/>
  </contact>

  <actuator>
    <position name="thumb_proximal_yaw"    joint="thumb_proximal_yaw_joint"    ctrlrange="0 1.308"/>
    <position name="thumb_proximal_pitch"  joint="thumb_proximal_pitch_joint"  ctrlrange="0 0.6"/>
    <position name="thumb_intermediate"    joint="thumb_intermediate_joint"    ctrlrange="0 0.8"/>
    <position name="thumb_distal"          joint="thumb_distal_joint"          ctrlrange="0 0.4"/>
    <position name="index_proximal"        joint="index_proximal_joint"        ctrlrange="0 1.47"/>
    <position name="index_intermediate"    joint="index_intermediate_joint"    ctrlrange="-0.04545 1.56"/>
    <position name="middle_proximal"       joint="middle_proximal_joint"       ctrlrange="0 1.47"/>
    <position name="middle_intermediate"   joint="middle_intermediate_joint"   ctrlrange="-0.04545 1.56"/>
    <position name="ring_proximal"         joint="ring_proximal_joint"         ctrlrange="0 1.47"/>
    <position name="ring_intermediate"     joint="ring_intermediate_joint"     ctrlrange="-0.04545 1.56"/>
    <position name="pinky_proximal"        joint="pinky_proximal_joint"        ctrlrange="0 1.47"/>
    <position name="pinky_intermediate"    joint="pinky_intermediate_joint"    ctrlrange="-0.04545 1.56"/>
  </actuator>
</mujoco>
