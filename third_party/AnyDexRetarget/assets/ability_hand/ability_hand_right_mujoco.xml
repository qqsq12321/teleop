<mujoco model="ability_hand">
  <compiler angle="radian" meshdir="./" autolimits="true"/>

  <option gravity="0 0 0"/>

  <default>
    <default class="ability_hand">
      <joint damping="0.05"/>
      <position kp="3" dampratio="1"/>
      <geom density="800"/>

      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2" rgba="0.7 0.7 0.7 1"/>
      </default>
      <default class="collision">
        <geom group="3" mass="0" contype="0" conaffinity="0" rgba="0 0 0 0"/>
      </default>
    </default>
  </default>

  <visual>
    <global offwidth="1280" offheight="1280"/>
    <quality shadowsize="4096"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texrepeat="5 5" reflectance="0.2"/>
    <material name="hand_gray" rgba="0.65 0.65 0.65 1"/>
    <material name="hand_dark" rgba="0.3 0.3 0.3 1"/>

    <mesh name="wristmesh" file="meshes/visual/wristmesh.obj"/>
    <mesh name="FB_palm_ref_MIR" file="meshes/visual/FB_palm_ref_MIR.obj"/>
    <mesh name="thumb-F1-MIR" file="meshes/visual/thumb-F1-MIR.obj"/>
    <mesh name="thumb-F2" file="meshes/visual/thumb-F2.obj"/>
    <mesh name="idx-F1" file="meshes/visual/idx-F1.obj"/>
    <mesh name="idx-F2" file="meshes/visual/idx-F2.obj"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <light pos="0.5 0.5 1" dir="-0.5 -0.5 -1"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Palm body: wrist + palm meshes + all finger bodies -->
    <body name="palm" childclass="ability_hand">
      <!-- Wrist mesh (base link, rotated by base_joint rpy="0 0 -1.57079") -->
      <geom quat="0.707109 0 0 -0.707105" type="mesh" mesh="wristmesh" class="visual" material="hand_dark"/>
      <!-- Palm mesh (thumb_base link) -->
      <geom pos="0.0037811 0.0240477 0.0323296" quat="0.0312561 -0.705981 -0.706848 -0.0312941" type="mesh" mesh="FB_palm_ref_MIR" class="visual" material="hand_gray"/>

      <!-- Thumb -->
      <body name="thumb_L1" pos="0.0037811 0.0240477 0.0323296" quat="0.636193 0.0281664 -0.0341016 0.770261">
        <inertial pos="0.014606 -0.00189085 -0.00311554" quat="0.306728 0.531258 0.293089 0.733336" mass="0.00268342" diaginertia="8.14795e-05 7.42718e-05 1.14409e-05"/>
        <joint name="thumb_q1" axis="0 0 1" range="-2.0944 0"/>
        <geom pos="0.0278284 0 0.0147507" quat="0.608761 0.793353 0 0" type="mesh" mesh="thumb-F1-MIR" class="visual" material="hand_gray"/>
        <body name="thumb_L2" pos="0.0278284 0 0.0147507" quat="0.608761 0.793353 0 0">
          <inertial pos="0.0300205 0.00559476 -0.00415044" quat="0.00721249 0.656735 -0.223684 0.720148" mass="0.0055" diaginertia="0.00180207 0.00170892 0.000287855"/>
          <joint name="thumb_q2" axis="0 0 1" range="0 2.0944"/>
          <geom pos="0.0651867 0.0233402 0.00393483" quat="3.21978e-07 -0.985259 -0.171069 5.59046e-08" type="mesh" mesh="thumb-F2" class="visual" material="hand_gray"/>
        </body>
      </body>

      <!-- Index finger -->
      <body name="index_L1" pos="-0.00927051 0.0279215 0.0958706" quat="0.393145 -0.472005 -0.538392 -0.576873">
        <inertial pos="0.0224191 -0.000157982 -1.31987e-05" quat="-0.00406251 0.706621 0.00934715 0.707518" mass="0.00635888" diaginertia="0.000381765 0.000369601 2.96432e-05"/>
        <joint name="index_q1" axis="0 0 1" range="0 2.0944"/>
        <geom pos="0.0384727 0.0032577 0" quat="0.999108 0 0 0.0422244" type="mesh" mesh="idx-F1" class="visual" material="hand_gray"/>
        <body name="index_L2" pos="0.0384727 0.0032577 0" quat="0.999108 0 0 0.0422244">
          <inertial pos="0.0133682 -0.00875392 -2.886e-05" quat="-0.161363 0.673074 0.216775 0.688434" mass="0.00645" diaginertia="0.000264645 0.000263553 1.71391e-05"/>
          <joint name="index_q2" axis="0 0 1" range="0 2.6586"/>
          <geom pos="0.0091241 0 0" type="mesh" mesh="idx-F2" class="visual" material="hand_gray"/>
        </body>
      </body>

      <!-- Middle finger -->
      <body name="middle_L1" pos="-0.0115173 0.00841711 0.0990634" quat="0.425011 -0.443228 -0.544452 -0.57139">
        <inertial pos="0.0224191 -0.000157982 -1.31987e-05" quat="-0.00406251 0.706621 0.00934715 0.707518" mass="0.00635888" diaginertia="0.000381765 0.000369601 2.96432e-05"/>
        <joint name="middle_q1" axis="0 0 1" range="0 2.0944"/>
        <geom pos="0.0384727 0.0032577 0" quat="0.999108 0 0 0.0422244" type="mesh" mesh="idx-F1" class="visual" material="hand_gray"/>
        <body name="middle_L2" pos="0.0384727 0.0032577 0" quat="0.999108 0 0 0.0422244">
          <inertial pos="0.0133682 -0.00875392 -2.886e-05" quat="-0.161363 0.673074 0.216775 0.688434" mass="0.00645" diaginertia="0.000264645 0.000263553 1.71391e-05"/>
          <joint name="middle_q2" axis="0 0 1" range="0 2.6586"/>
          <geom pos="0.0091241 0 0" type="mesh" mesh="idx-F2" class="visual" material="hand_gray"/>
        </body>
      </body>

      <!-- Ring finger -->
      <body name="ring_L1" pos="-0.0103946 -0.011753 0.0967038" quat="0.455652 -0.411901 -0.551423 -0.564493">
        <inertial pos="0.0224191 -0.000157982 -1.31987e-05" quat="-0.00406251 0.706621 0.00934715 0.707518" mass="0.00635888" diaginertia="0.000381765 0.000369601 2.96432e-05"/>
        <joint name="ring_q1" axis="0 0 1" range="0 2.0944"/>
        <geom pos="0.0384727 0.0032577 0" quat="0.999108 0 0 0.0422244" type="mesh" mesh="idx-F1" class="visual" material="hand_gray"/>
        <body name="ring_L2" pos="0.0384727 0.0032577 0" quat="0.999108 0 0 0.0422244">
          <inertial pos="0.0133682 -0.00875392 -2.886e-05" quat="-0.161363 0.673074 0.216775 0.688434" mass="0.00645" diaginertia="0.000264645 0.000263553 1.71391e-05"/>
          <joint name="ring_q2" axis="0 0 1" range="0 2.6586"/>
          <geom pos="0.0091241 0 0" type="mesh" mesh="idx-F2" class="visual" material="hand_gray"/>
        </body>
      </body>

      <!-- Pinky finger -->
      <body name="pinky_L1" pos="-0.00716263 -0.0308633 0.0907346" quat="0.470098 -0.395543 -0.568594 -0.547042">
        <inertial pos="0.0224191 -0.000157982 -1.31987e-05" quat="-0.00406251 0.706621 0.00934715 0.707518" mass="0.00635888" diaginertia="0.000381765 0.000369601 2.96432e-05"/>
        <joint name="pinky_q1" axis="0 0 1" range="0 2.0944"/>
        <geom pos="0.0384727 0.0032577 0" quat="0.999108 0 0 0.0422244" type="mesh" mesh="idx-F1" class="visual" material="hand_gray"/>
        <body name="pinky_L2" pos="0.0384727 0.0032577 0" quat="0.999108 0 0 0.0422244">
          <inertial pos="0.0133682 -0.00875392 -2.886e-05" quat="-0.161363 0.673074 0.216775 0.688434" mass="0.00645" diaginertia="0.000264645 0.000263553 1.71391e-05"/>
          <joint name="pinky_q2" axis="0 0 1" range="0 2.6586"/>
          <geom pos="0.0091241 0 0" type="mesh" mesh="idx-F2" class="visual" material="hand_gray"/>
        </body>
      </body>
    </body>
  </worldbody>

  <contact>
    <exclude body1="palm" body2="thumb_L1"/>
    <exclude body1="palm" body2="index_L1"/>
    <exclude body1="palm" body2="middle_L1"/>
    <exclude body1="palm" body2="ring_L1"/>
    <exclude body1="palm" body2="pinky_L1"/>
  </contact>

  <actuator>
    <position name="thumb_q1_act"  joint="thumb_q1"  ctrlrange="-2.0944 0"/>
    <position name="thumb_q2_act"  joint="thumb_q2"  ctrlrange="0 2.0944"/>
    <position name="index_q1_act"  joint="index_q1"  ctrlrange="0 2.0944"/>
    <position name="index_q2_act"  joint="index_q2"  ctrlrange="0 2.6586"/>
    <position name="middle_q1_act" joint="middle_q1" ctrlrange="0 2.0944"/>
    <position name="middle_q2_act" joint="middle_q2" ctrlrange="0 2.6586"/>
    <position name="ring_q1_act"   joint="ring_q1"   ctrlrange="0 2.0944"/>
    <position name="ring_q2_act"   joint="ring_q2"   ctrlrange="0 2.6586"/>
    <position name="pinky_q1_act"  joint="pinky_q1"  ctrlrange="0 2.0944"/>
    <position name="pinky_q2_act"  joint="pinky_q2"  ctrlrange="0 2.6586"/>
  </actuator>
</mujoco>
