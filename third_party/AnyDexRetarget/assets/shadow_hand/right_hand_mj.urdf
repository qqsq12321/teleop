<?xml version="1.0"?>
<!-- URDF for Shadow Hand Right - Matching MuJoCo Menagerie joint definitions -->
<!-- Joint axes and ranges exactly match scene_right.xml -->
<robot name="shadow_hand_right_mj">

  <!-- Palm (root link) -->
  <link name="rh_palm">
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0.035"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0003" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <!-- ==================== INDEX FINGER (FF) ==================== -->
  <link name="rh_ffknuckle">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
    </inertial>
  </link>
  <joint name="rh_FFJ4" type="revolute">
    <origin xyz="0.033 0 0.095" rpy="0 0 0"/>
    <parent link="rh_palm"/>
    <child link="rh_ffknuckle"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-0.3491" upper="0.3491" effort="2" velocity="4"/>
  </joint>

  <link name="rh_ffproximal">
    <inertial>
      <mass value="0.03"/>
      <origin xyz="0 0 0.0225"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="3e-6"/>
    </inertial>
  </link>
  <joint name="rh_FFJ3" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="rh_ffknuckle"/>
    <child link="rh_ffproximal"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.2618" upper="1.5708" effort="2" velocity="4"/>
  </joint>

  <link name="rh_ffmiddle">
    <inertial>
      <mass value="0.017"/>
      <origin xyz="0 0 0.0125"/>
      <inertia ixx="3e-6" ixy="0" ixz="0" iyy="3e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>
  <joint name="rh_FFJ2" type="revolute">
    <origin xyz="0 0 0.045" rpy="0 0 0"/>
    <parent link="rh_ffproximal"/>
    <child link="rh_ffmiddle"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.5708" effort="2" velocity="4"/>
  </joint>

  <link name="rh_ffdistal">
    <inertial>
      <mass value="0.012"/>
      <origin xyz="0 0 0.012"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="5e-7"/>
    </inertial>
  </link>
  <joint name="rh_FFJ1" type="revolute">
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
    <parent link="rh_ffmiddle"/>
    <child link="rh_ffdistal"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.5708" effort="2" velocity="4"/>
  </joint>

  <link name="rh_fftip">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
    </inertial>
  </link>
  <joint name="rh_fftip_fixed" type="fixed">
    <origin xyz="0 0 0.026" rpy="0 0 0"/>
    <parent link="rh_ffdistal"/>
    <child link="rh_fftip"/>
  </joint>

  <!-- ==================== MIDDLE FINGER (MF) ==================== -->
  <link name="rh_mfknuckle">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
    </inertial>
  </link>
  <joint name="rh_MFJ4" type="revolute">
    <origin xyz="0.011 0 0.099" rpy="0 0 0"/>
    <parent link="rh_palm"/>
    <child link="rh_mfknuckle"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-0.3491" upper="0.3491" effort="2" velocity="4"/>
  </joint>

  <link name="rh_mfproximal">
    <inertial>
      <mass value="0.03"/>
      <origin xyz="0 0 0.0225"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="3e-6"/>
    </inertial>
  </link>
  <joint name="rh_MFJ3" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="rh_mfknuckle"/>
    <child link="rh_mfproximal"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.2618" upper="1.5708" effort="2" velocity="4"/>
  </joint>

  <link name="rh_mfmiddle">
    <inertial>
      <mass value="0.017"/>
      <origin xyz="0 0 0.0125"/>
      <inertia ixx="3e-6" ixy="0" ixz="0" iyy="3e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>
  <joint name="rh_MFJ2" type="revolute">
    <origin xyz="0 0 0.045" rpy="0 0 0"/>
    <parent link="rh_mfproximal"/>
    <child link="rh_mfmiddle"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.5708" effort="2" velocity="4"/>
  </joint>

  <link name="rh_mfdistal">
    <inertial>
      <mass value="0.012"/>
      <origin xyz="0 0 0.012"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="5e-7"/>
    </inertial>
  </link>
  <joint name="rh_MFJ1" type="revolute">
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
    <parent link="rh_mfmiddle"/>
    <child link="rh_mfdistal"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.5708" effort="2" velocity="4"/>
  </joint>

  <link name="rh_mftip">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
    </inertial>
  </link>
  <joint name="rh_mftip_fixed" type="fixed">
    <origin xyz="0 0 0.026" rpy="0 0 0"/>
    <parent link="rh_mfdistal"/>
    <child link="rh_mftip"/>
  </joint>

  <!-- ==================== RING FINGER (RF) ==================== -->
  <link name="rh_rfknuckle">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
    </inertial>
  </link>
  <joint name="rh_RFJ4" type="revolute">
    <origin xyz="-0.011 0 0.095" rpy="0 0 0"/>
    <parent link="rh_palm"/>
    <child link="rh_rfknuckle"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.3491" upper="0.3491" effort="2" velocity="4"/>
  </joint>

  <link name="rh_rfproximal">
    <inertial>
      <mass value="0.03"/>
      <origin xyz="0 0 0.0225"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="3e-6"/>
    </inertial>
  </link>
  <joint name="rh_RFJ3" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="rh_rfknuckle"/>
    <child link="rh_rfproximal"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.2618" upper="1.5708" effort="2" velocity="4"/>
  </joint>

  <link name="rh_rfmiddle">
    <inertial>
      <mass value="0.017"/>
      <origin xyz="0 0 0.0125"/>
      <inertia ixx="3e-6" ixy="0" ixz="0" iyy="3e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>
  <joint name="rh_RFJ2" type="revolute">
    <origin xyz="0 0 0.045" rpy="0 0 0"/>
    <parent link="rh_rfproximal"/>
    <child link="rh_rfmiddle"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.5708" effort="2" velocity="4"/>
  </joint>

  <link name="rh_rfdistal">
    <inertial>
      <mass value="0.012"/>
      <origin xyz="0 0 0.012"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="5e-7"/>
    </inertial>
  </link>
  <joint name="rh_RFJ1" type="revolute">
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
    <parent link="rh_rfmiddle"/>
    <child link="rh_rfdistal"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.5708" effort="2" velocity="4"/>
  </joint>

  <link name="rh_rftip">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
    </inertial>
  </link>
  <joint name="rh_rftip_fixed" type="fixed">
    <origin xyz="0 0 0.026" rpy="0 0 0"/>
    <parent link="rh_rfdistal"/>
    <child link="rh_rftip"/>
  </joint>

  <!-- ==================== LITTLE FINGER (LF) ==================== -->
  <link name="rh_lfmetacarpal">
    <inertial>
      <mass value="0.03"/>
      <origin xyz="0 0 0.033"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="3e-6"/>
    </inertial>
  </link>
  <joint name="rh_LFJ5" type="revolute">
    <origin xyz="-0.033 0 0.02071" rpy="0 0 0"/>
    <parent link="rh_palm"/>
    <child link="rh_lfmetacarpal"/>
    <axis xyz="0.573576 0 0.819152"/>
    <limit lower="0" upper="0.7854" effort="2" velocity="4"/>
  </joint>

  <link name="rh_lfknuckle">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
    </inertial>
  </link>
  <joint name="rh_LFJ4" type="revolute">
    <origin xyz="0 0 0.06579" rpy="0 0 0"/>
    <parent link="rh_lfmetacarpal"/>
    <child link="rh_lfknuckle"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.3491" upper="0.3491" effort="2" velocity="4"/>
  </joint>

  <link name="rh_lfproximal">
    <inertial>
      <mass value="0.03"/>
      <origin xyz="0 0 0.0225"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="3e-6"/>
    </inertial>
  </link>
  <joint name="rh_LFJ3" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="rh_lfknuckle"/>
    <child link="rh_lfproximal"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.2618" upper="1.5708" effort="2" velocity="4"/>
  </joint>

  <link name="rh_lfmiddle">
    <inertial>
      <mass value="0.017"/>
      <origin xyz="0 0 0.0125"/>
      <inertia ixx="3e-6" ixy="0" ixz="0" iyy="3e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>
  <joint name="rh_LFJ2" type="revolute">
    <origin xyz="0 0 0.045" rpy="0 0 0"/>
    <parent link="rh_lfproximal"/>
    <child link="rh_lfmiddle"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.5708" effort="2" velocity="4"/>
  </joint>

  <link name="rh_lfdistal">
    <inertial>
      <mass value="0.012"/>
      <origin xyz="0 0 0.012"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="5e-7"/>
    </inertial>
  </link>
  <joint name="rh_LFJ1" type="revolute">
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
    <parent link="rh_lfmiddle"/>
    <child link="rh_lfdistal"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.5708" effort="2" velocity="4"/>
  </joint>

  <link name="rh_lftip">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
    </inertial>
  </link>
  <joint name="rh_lftip_fixed" type="fixed">
    <origin xyz="0 0 0.026" rpy="0 0 0"/>
    <parent link="rh_lfdistal"/>
    <child link="rh_lftip"/>
  </joint>

  <!-- ==================== THUMB (TH) ==================== -->
  <!-- Note: thbase has a rotation of 22.5 deg around Y (quat 0.9239,0,0.3827,0) -->
  <link name="rh_thbase">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
    </inertial>
  </link>
  <joint name="rh_THJ5" type="revolute">
    <origin xyz="0.034 -0.00858 0.029" rpy="0 0.7854 0"/>
    <parent link="rh_palm"/>
    <child link="rh_thbase"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-1.0472" upper="1.0472" effort="2" velocity="4"/>
  </joint>

  <link name="rh_thproximal">
    <inertial>
      <mass value="0.04"/>
      <origin xyz="0 0 0.019"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="3e-6"/>
    </inertial>
  </link>
  <joint name="rh_THJ4" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="rh_thbase"/>
    <child link="rh_thproximal"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.2217" effort="2" velocity="4"/>
  </joint>

  <link name="rh_thhub">
    <inertial>
      <mass value="0.005"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="3e-7"/>
    </inertial>
  </link>
  <joint name="rh_THJ3" type="revolute">
    <origin xyz="0 0 0.038" rpy="0 0 0"/>
    <parent link="rh_thproximal"/>
    <child link="rh_thhub"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.2094" upper="0.2094" effort="1" velocity="4"/>
  </joint>

  <link name="rh_thmiddle">
    <inertial>
      <mass value="0.02"/>
      <origin xyz="0 0 0.016"/>
      <inertia ixx="5e-6" ixy="0" ixz="0" iyy="5e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>
  <joint name="rh_THJ2" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="rh_thhub"/>
    <child link="rh_thmiddle"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-0.6981" upper="0.6981" effort="1" velocity="4"/>
  </joint>

  <!-- Note: thdistal has a rotation (quat 0.7071,0,0,-0.7071 = -90 deg around Z) -->
  <link name="rh_thdistal">
    <inertial>
      <mass value="0.017"/>
      <origin xyz="0 0 0.0146"/>
      <inertia ixx="2e-6" ixy="0" ixz="0" iyy="2e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>
  <joint name="rh_THJ1" type="revolute">
