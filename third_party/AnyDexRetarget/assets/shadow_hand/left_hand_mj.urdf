<?xml version="1.0"?>
<!-- URDF for Shadow Hand Left - Matching MuJoCo Menagerie joint definitions -->
<!-- Joint axes and ranges exactly match scene_left.xml (mirrored from right) -->
<robot name="shadow_hand_left_mj">

  <!-- Palm (root link) -->
  <link name="lh_palm">
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0.035"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0003" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <!-- ==================== INDEX FINGER (FF) ==================== -->
  <link name="lh_ffknuckle">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
    </inertial>
  </link>
  <joint name="lh_FFJ4" type="revolute">
    <origin xyz="-0.033 0 0.095" rpy="0 0 0"/>
    <parent link="lh_palm"/>
    <child link="lh_ffknuckle"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.3491" upper="0.3491" effort="2" velocity="4"/>
  </joint>

  <link name="lh_ffproximal">
    <inertial>
      <mass value="0.03"/>
      <origin xyz="0 0 0.0225"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="3e-6"/>
    </inertial>
  </link>
  <joint name="lh_FFJ3" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="lh_ffknuckle"/>
    <child link="lh_ffproximal"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.2618" upper="1.5708" effort="2" velocity="4"/>
  </joint>

  <link name="lh_ffmiddle">
    <inertial>
      <mass value="0.017"/>
      <origin xyz="0 0 0.0125"/>
      <inertia ixx="3e-6" ixy="0" ixz="0" iyy="3e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>
  <joint name="lh_FFJ2" type="revolute">
    <origin xyz="0 0 0.045" rpy="0 0 0"/>
    <parent link="lh_ffproximal"/>
    <child link="lh_ffmiddle"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.5708" effort="2" velocity="4"/>
  </joint>

  <link name="lh_ffdistal">
    <inertial>
      <mass value="0.012"/>
      <origin xyz="0 0 0.012"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="5e-7"/>
    </inertial>
  </link>
  <joint name="lh_FFJ1" type="revolute">
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
    <parent link="lh_ffmiddle"/>
    <child link="lh_ffdistal"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.5708" effort="2" velocity="4"/>
  </joint>

  <link name="lh_fftip">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
    </inertial>
  </link>
  <joint name="lh_fftip_fixed" type="fixed">
    <origin xyz="0 0 0.026" rpy="0 0 0"/>
    <parent link="lh_ffdistal"/>
    <child link="lh_fftip"/>
  </joint>

  <!-- ==================== MIDDLE FINGER (MF) ==================== -->
  <link name="lh_mfknuckle">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
    </inertial>
  </link>
  <joint name="lh_MFJ4" type="revolute">
    <origin xyz="-0.011 0 0.099" rpy="0 0 0"/>
    <parent link="lh_palm"/>
    <child link="lh_mfknuckle"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.3491" upper="0.3491" effort="2" velocity="4"/>
  </joint>

  <link name="lh_mfproximal">
    <inertial>
      <mass value="0.03"/>
      <origin xyz="0 0 0.0225"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="3e-6"/>
    </inertial>
  </link>
  <joint name="lh_MFJ3" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="lh_mfknuckle"/>
    <child link="lh_mfproximal"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.2618" upper="1.5708" effort="2" velocity="4"/>
  </joint>

  <link name="lh_mfmiddle">
    <inertial>
      <mass value="0.017"/>
      <origin xyz="0 0 0.0125"/>
      <inertia ixx="3e-6" ixy="0" ixz="0" iyy="3e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>
  <joint name="lh_MFJ2" type="revolute">
    <origin xyz="0 0 0.045" rpy="0 0 0"/>
    <parent link="lh_mfproximal"/>
    <child link="lh_mfmiddle"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.5708" effort="2" velocity="4"/>
  </joint>

  <link name="lh_mfdistal">
    <inertial>
      <mass value="0.012"/>
      <origin xyz="0 0 0.012"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="5e-7"/>
    </inertial>
  </link>
  <joint name="lh_MFJ1" type="revolute">
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
    <parent link="lh_mfmiddle"/>
    <child link="lh_mfdistal"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.5708" effort="2" velocity="4"/>
  </joint>

  <link name="lh_mftip">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
    </inertial>
  </link>
  <joint name="lh_mftip_fixed" type="fixed">
    <origin xyz="0 0 0.026" rpy="0 0 0"/>
    <parent link="lh_mfdistal"/>
    <child link="lh_mftip"/>
  </joint>

  <!-- ==================== RING FINGER (RF) ==================== -->
  <link name="lh_rfknuckle">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
    </inertial>
  </link>
  <joint name="lh_RFJ4" type="revolute">
    <origin xyz="0.011 0 0.095" rpy="0 0 0"/>
    <parent link="lh_palm"/>
    <child link="lh_rfknuckle"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-0.3491" upper="0.3491" effort="2" velocity="4"/>
  </joint>

  <link name="lh_rfproximal">
    <inertial>
      <mass value="0.03"/>
      <origin xyz="0 0 0.0225"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="3e-6"/>
    </inertial>
  </link>
  <joint name="lh_RFJ3" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="lh_rfknuckle"/>
    <child link="lh_rfproximal"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.2618" upper="1.5708" effort="2" velocity="4"/>
  </joint>

  <link name="lh_rfmiddle">
    <inertial>
      <mass value="0.017"/>
      <origin xyz="0 0 0.0125"/>
      <inertia ixx="3e-6" ixy="0" ixz="0" iyy="3e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>
  <joint name="lh_RFJ2" type="revolute">
    <origin xyz="0 0 0.045" rpy="0 0 0"/>
    <parent link="lh_rfproximal"/>
    <child link="lh_rfmiddle"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.5708" effort="2" velocity="4"/>
  </joint>

  <link name="lh_rfdistal">
    <inertial>
      <mass value="0.012"/>
      <origin xyz="0 0 0.012"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="5e-7"/>
    </inertial>
  </link>
  <joint name="lh_RFJ1" type="revolute">
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
    <parent link="lh_rfmiddle"/>
    <child link="lh_rfdistal"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.5708" effort="2" velocity="4"/>
  </joint>

  <link name="lh_rftip">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
    </inertial>
  </link>
  <joint name="lh_rftip_fixed" type="fixed">
    <origin xyz="0 0 0.026" rpy="0 0 0"/>
    <parent link="lh_rfdistal"/>
    <child link="lh_rftip"/>
  </joint>

  <!-- ==================== LITTLE FINGER (LF) ==================== -->
  <link name="lh_lfmetacarpal">
    <inertial>
      <mass value="0.03"/>
      <origin xyz="0 0 0.033"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="3e-6"/>
    </inertial>
  </link>
  <joint name="lh_LFJ5" type="revolute">
    <origin xyz="0.033 0 0.02071" rpy="0 0 0"/>
    <parent link="lh_palm"/>
    <child link="lh_lfmetacarpal"/>
    <axis xyz="-0.573576 0 0.819152"/>
    <limit lower="0" upper="0.7854" effort="2" velocity="4"/>
  </joint>

  <link name="lh_lfknuckle">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
    </inertial>
  </link>
  <joint name="lh_LFJ4" type="revolute">
    <origin xyz="0 0 0.06579" rpy="0 0 0"/>
    <parent link="lh_lfmetacarpal"/>
    <child link="lh_lfknuckle"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-0.3491" upper="0.3491" effort="2" velocity="4"/>
  </joint>

  <link name="lh_lfproximal">
    <inertial>
      <mass value="0.03"/>
      <origin xyz="0 0 0.0225"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="3e-6"/>
    </inertial>
  </link>
  <joint name="lh_LFJ3" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="lh_lfknuckle"/>
    <child link="lh_lfproximal"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.2618" upper="1.5708" effort="2" velocity="4"/>
  </joint>

  <link name="lh_lfmiddle">
    <inertial>
      <mass value="0.017"/>
      <origin xyz="0 0 0.0125"/>
      <inertia ixx="3e-6" ixy="0" ixz="0" iyy="3e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>
  <joint name="lh_LFJ2" type="revolute">
    <origin xyz="0 0 0.045" rpy="0 0 0"/>
    <parent link="lh_lfproximal"/>
    <child link="lh_lfmiddle"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.5708" effort="2" velocity="4"/>
  </joint>

  <link name="lh_lfdistal">
    <inertial>
      <mass value="0.012"/>
      <origin xyz="0 0 0.012"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="5e-7"/>
    </inertial>
  </link>
  <joint name="lh_LFJ1" type="revolute">
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
    <parent link="lh_lfmiddle"/>
    <child link="lh_lfdistal"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.5708" effort="2" velocity="4"/>
  </joint>

  <link name="lh_lftip">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
    </inertial>
  </link>
  <joint name="lh_lftip_fixed" type="fixed">
    <origin xyz="0 0 0.026" rpy="0 0 0"/>
    <parent link="lh_lfdistal"/>
    <child link="lh_lftip"/>
  </joint>

  <!-- ==================== THUMB (TH) ==================== -->
  <!-- Note: thbase has a rotation of -22.5 deg around Y for left hand (mirrored) -->
  <link name="lh_thbase">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
    </inertial>
  </link>
  <joint name="lh_THJ5" type="revolute">
    <origin xyz="-0.034 -0.00858 0.029" rpy="0 -0.7854 0"/>
    <parent link="lh_palm"/>
    <child link="lh_thbase"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.0472" upper="1.0472" effort="2" velocity="4"/>
  </joint>

  <link name="lh_thproximal">
    <inertial>
      <mass value="0.04"/>
      <origin xyz="0 0 0.019"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="3e-6"/>
    </inertial>
  </link>
  <joint name="lh_THJ4" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="lh_thbase"/>
    <child link="lh_thproximal"/>
    <axis xyz="-1 0 0"/>
    <limit lower="0" upper="1.2217" effort="2" velocity="4"/>
  </joint>

  <link name="lh_thhub">
    <inertial>
      <mass value="0.005"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="3e-7"/>
    </inertial>
  </link>
  <joint name="lh_THJ3" type="revolute">
    <origin xyz="0 0 0.038" rpy="0 0 0"/>
    <parent link="lh_thproximal"/>
    <child link="lh_thhub"/>
    <axis xyz="-1 0 0"/>
    <limit lower="-0.2094" upper="0.2094" effort="1" velocity="4"/>
  </joint>

  <link name="lh_thmiddle">
    <inertial>
      <mass value="0.02"/>
      <origin xyz="0 0 0.016"/>
      <inertia ixx="5e-6" ixy="0" ixz="0" iyy="5e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>
  <joint name="lh_THJ2" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="lh_thhub"/>
    <child link="lh_thmiddle"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-0.6981" upper="0.6981" effort="1" velocity="4"/>
  </joint>

  <!-- Note: thdistal has a rotation (quat 0.7071,0,0,0.7071 = +90 deg around Z for left) -->
  <link name="lh_thdistal">
    <inertial>
      <mass value="0.017"/>
      <origin xyz="0 0 0.0146"/>
      <inertia ixx="2e-6" ixy="0" ixz="0" iyy="2e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>
  <joint name="lh_THJ1" type="revolute">
    <origin xyz="0 0 0.032" rpy="0 0 1.5708"/>
    <parent link="lh_thmiddle"/>
    <child link="lh_thdistal"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.2618" upper="1.5708" effort="0.5" velocity="4"/>
  </joint>

  <link name="lh_thtip">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
    </inertial>
  </link>
  <joint name="lh_thtip_fixed" type="fixed">
    <origin xyz="0 0 0.027" rpy="0 0 0"/>
    <parent link="lh_thdistal"/>
    <child link="lh_thtip"/>
  </joint>

</robot>
